# ─── Bloom Configuration ─────────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# All settings are optional — Bloom works out of the box with defaults.

# Server port (default: 8080)
PORT=8080

# Database file path (default: period_tracker.db in working directory)
DB_PATH=period_tracker.db

# ─── Email Notifications (Optional — choose ONE method) ────────────────

# Option A: HTTP Email API (recommended if you have an email microservice)
EMAIL_API_URL=
EMAIL_API_KEY=

# Option B: Direct SMTP (e.g. Gmail App Password)
# Works with Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASS=

# ─── Database Encryption (Optional) ─────────────────────────────────────
# Encrypt the entire database at rest with AES-256-GCM.
# When set, the database file is decrypted on startup and re-encrypted on
# shutdown (and every 5 minutes for crash resilience).
# Must be at least 8 characters. Use a strong, unique passphrase.
# ⚠️ If you lose this key, your data is gone forever.

ENCRYPTION_KEY=

# ─── Notes ───────────────────────────────────────────────────────────────
# • All data is stored locally in SQLite — nothing leaves your server
# • No external API calls, no tracking, no analytics
# • Partner notifications require SMTP credentials above
# • Backups are encrypted with AES-256-GCM (password set per-download)
# • Database encryption adds at-rest protection for the SQLite file
